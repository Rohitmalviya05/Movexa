# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logistics_db
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Pricing (base rates in INR)
BIKE_BASE_FARE=30
BIKE_PER_KM=8
AUTO_BASE_FARE=50
AUTO_PER_KM=12
PICKUP_BASE_FARE=100
PICKUP_PER_KM=20
MINI_TRUCK_BASE_FARE=200
MINI_TRUCK_PER_KM=35

# Surge pricing multiplier cap
MAX_SURGE_MULTIPLIER=3.0

# OTP expiry (seconds)
OTP_EXPIRY=300

# Driver search radius (km)
DRIVER_SEARCH_RADIUS=10
